# =====================================================================
# SIM Pesantren — Environment Variables Template
# Salin file ini menjadi .env.local untuk development lokal
# Isi nilai yang sama di Vercel > Project Settings > Environment Variables
# =====================================================================

# --- Supabase (WAJIB) ---
# Dapatkan dari: https://supabase.com > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# --- Webhook (Opsional) ---
# Token rahasia untuk memverifikasi webhook dari Supabase
WEBHOOK_SECRET_TOKEN=ganti-dengan-token-rahasia-anda

# --- App URL (WAJIB untuk Production) ---
# URL publik aplikasi (digunakan untuk link di undangan WhatsApp)
# Contoh: https://sim-pesantren.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- WhatsApp API via Fonnte (Opsional) ---
# Dapatkan dari: https://fonnte.com > Dashboard > Token
FONNTE_API_TOKEN=your-fonnte-api-token-here
